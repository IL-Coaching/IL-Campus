{
  "name": "il-campus",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "schema": "src/baseDatos/esquema.prisma"
  },
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema=src/baseDatos/esquema.prisma && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unitarios",
    "test:integracion": "vitest run tests/integracion",
    "test:seguridad": "vitest run tests/seguridad",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run lint",
      "npm run typecheck"
    ]
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/supabase-js": "^2.97.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "html2pdf.js": "^0.14.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.575.0",
    "next": "^14.2.35",
    "otplib": "^13.3.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
