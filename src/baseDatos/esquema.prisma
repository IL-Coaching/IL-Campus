generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Entrenador {
  id             String            @id @default(uuid())
  nombre         String
  email          String            @unique
  password       String
  telefono       String?
  activo         Boolean           @default(true)
  creadoEn       DateTime          @default(now())
  mfaEnabled     Boolean           @default(false)
  mfaSecret      String?
  landingBioUrl  String?
  landingHeroUrl String?
  avatarUrl      String?
  clientes       Cliente[]
  configLanding  ConfigLanding?
  ejercicios     Ejercicio[]
  notas          NotaEntrenador[]
  notificaciones Notificacion[]
  planes         Plan[]
  rutinas        RutinaPlantilla[]
}

model Plan {
  id                String         @id @default(uuid())
  entrenadorId      String
  nombre            String
  precio            Float
  precioPromocional Float?
  mesesPromocion    Int?
  duracionDias      Int
  descripcion       String?
  beneficios        String[]
  visible           Boolean        @default(true)
  creadoEn          DateTime       @default(now())
  entrenador        Entrenador     @relation(fields: [entrenadorId], references: [id])
  asignaciones      PlanAsignado[]
}

model Ejercicio {
  id                     String                  @id @default(uuid())
  entrenadorId           String
  nombre                 String
  nombresAlternativos    String[]
  descripcion            String?
  erroresComunes         String?
  musculoPrincipal       GrupoMuscular
  musculosSecundarios    GrupoMuscular[]
  articulacion           TipoArticulacion
  patron                 PatronMovimiento
  equipamiento           TipoEquipamiento[]
  lateralidad            Lateralidad
  posicionCarga          PosicionCarga           @default(NEUTRA)
  nivelTecnico           NivelTecnico            @default(BASICO)
  urlVideo               String?
  thumbnailUrl           String?
  origen                 OrigenEjercicio         @default(BIBLIOTECA_IL)
  visibleParaClientes    Boolean                 @default(true)
  archivado              Boolean                 @default(false)
  creadoEn               DateTime                @default(now())
  actualizadoEn          DateTime                @updatedAt
  alertasEstancamiento   AlertaEstancamiento[]
  configsTesteo          ConfigTesteoEjercicio[]
  entrenador             Entrenador              @relation(fields: [entrenadorId], references: [id])
  ejerciciosPlanificados EjercicioPlanificado[]
  ejerciciosRutina       EjercicioRutina[]
  porcentajesCliente     PorcentajesCliente[]
  resultadosTesteo       ResultadoTesteo[]
}

model Cliente {
  id                    String                 @id @default(uuid())
  entrenadorId          String
  nombre                String
  email                 String                 @unique
  password              String?
  telefono              String?
  genero                String?
  fechaAlta             DateTime               @default(now())
  activo                Boolean                @default(true)
  notas                 String?
  forcePasswordChange   Boolean                @default(false)
  invitationExpires     DateTime?
  invitationToken       String?                @unique
  lastLogin             DateTime?
  passwordResetExpires  DateTime?
  passwordResetToken    String?                @unique
  enEstasis             Boolean                @default(false)
  esVIP                 Boolean                @default(false)
  alertasEstancamiento  AlertaEstancamiento[]
  auditorias            AuditoriaCliente[]
  checkins              Checkin[]
  cicloMenstrual        CicloMenstrual?
  entrenador            Entrenador             @relation(fields: [entrenadorId], references: [id])
  cobros                Cobro[]
  formularioInscripcion FormularioInscripcion?
  macrociclos           Macrociclo[]
  mensajes              Mensaje[]
  perfilRespuesta       PerfilRespuesta?
  planesAsignados       PlanAsignado[]
  porcentajesCliente    PorcentajesCliente[]
  registrosAdherencia   RegistroAdherencia[]
  resultadosTesteo      ResultadoTesteo[]
  sesiones              SesionRegistrada[]
  gamificacion          GamificacionCliente?
}

model PlanAsignado {
  id               String   @id @default(uuid())
  clienteId        String
  planId           String
  fechaInicio      DateTime
  fechaVencimiento DateTime
  estado           String
  creadoEn         DateTime @default(now())
  cobros           Cobro[]
  cliente          Cliente  @relation(fields: [clienteId], references: [id])
  plan             Plan     @relation(fields: [planId], references: [id])
}

model FormularioInscripcion {
  id                  String   @id @default(uuid())
  clienteId           String   @unique
  datosPersonales     Json?
  contacto            Json?
  consentimiento      Json?
  saludMedica         Json?
  estiloDeVida        Json?
  experiencia         Json?
  objetivos           Json?
  disponibilidad      Json?
  personalizacion     Json?
  condicionesClinicas String[]
  creadoEn            DateTime @default(now())
  cliente             Cliente  @relation(fields: [clienteId], references: [id])
}

model AuditoriaCliente {
  id            String   @id @default(uuid())
  clienteId     String
  campo         String
  valorViejo    String?
  valorNuevo    String?
  modificadoPor String   @default("SISTEMA")
  fecha         DateTime @default(now())
  cliente       Cliente  @relation(fields: [clienteId], references: [id])
}

model CicloMenstrual {
  id                     String   @id @default(uuid())
  clienteId              String   @unique
  activo                 Boolean  @default(true)
  duracionCiclo          Int
  fechaInicioUltimoCiclo DateTime
  creadoEn               DateTime @default(now())
  cliente                Cliente  @relation(fields: [clienteId], references: [id])
}

model Macrociclo {
  id               String          @id @default(uuid())
  clienteId        String
  duracionSemanas  Int
  fechaInicio      DateTime
  notas            String?
  creadoEn         DateTime        @default(now())
  bloquesMensuales BloqueMensual[]
  cliente          Cliente         @relation(fields: [clienteId], references: [id])
}

model BloqueMensual {
  id              String     @id @default(uuid())
  macrocicloId    String
  nombre          String?
  objetivo        String
  duracion        Int
  metodo          String?
  rangoReferencia String?
  macrociclo      Macrociclo @relation(fields: [macrocicloId], references: [id])
  semanas         Semana[]
}

model Semana {
  id                  String                  @id @default(uuid())
  bloqueMensualId     String
  numeroSemana        Int
  objetivoSemana      String
  RIRobjetivo         Int
  volumenEstimado     String
  esFaseDeload        Boolean                 @default(false)
  esSemanaTesteo      Boolean                 @default(false)
  tipoCarga           TipoCarga?
  modeloPeriodizacion ModeloPeriodizacion     @default(LINEAL)
  fasesCiclo          String?
  checkinRequerido    Boolean                 @default(false)
  configsTesteo       ConfigTesteoEjercicio[]
  diasSesion          DiaSesion[]
  bloqueMensual       BloqueMensual           @relation(fields: [bloqueMensualId], references: [id])
  volumenesSemanales  VolumenSemanal[]
}

model VolumenSemanal {
  id             String  @id @default(uuid())
  semanaId       String
  grupoMuscular  String
  seriesTotal    Int
  bajoDeLaMinima Boolean @default(false)
  semana         Semana  @relation(fields: [semanaId], references: [id])
}

model DiaSesion {
  id             String                 @id @default(uuid())
  semanaId       String
  diaSemana      String
  focoMuscular   String
  notas          String?
  semana         Semana                 @relation(fields: [semanaId], references: [id])
  bloques        BloqueSesion[]
  ejercicios     EjercicioPlanificado[]
  sesionesReales SesionRegistrada[]
}

model BloqueSesion {
  id             String                 @id @default(uuid())
  diaId          String
  dia            DiaSesion              @relation(fields: [diaId], references: [id], onDelete: Cascade)
  nombre         String?                // Ej: "Activación Nerviosa", "Fuerza Estructural"
  orden          Int                    @default(1)
  modalidad      ModalidadBloque        @default(SECUENCIAL)
  ejercicios     EjercicioPlanificado[]
}

enum ModalidadBloque {
  SECUENCIAL
  CIRCUITO
  SUPERSERIE
  AMRAP
  EMOM
}

model EjercicioPlanificado {
  id                   String            @id @default(uuid())
  diaId                String
  bloqueId             String?
  bloque               BloqueSesion?     @relation(fields: [bloqueId], references: [id], onDelete: Cascade)
  ejercicioId          String?
  nombreLibre          String?
  esBiblioteca         Boolean           @default(false)
  series               Int
  repsMin              Int
  repsMax              Int
  RIR                  Int?
  tempo                String?
  tempoExcentrica      Int?
  tempoPausa           Int?
  tempoConcentrica     Int?
  tempoPausaArriba     Int?
  esUltimaSerieAlFallo Boolean           @default(false)
  descansoSegundos     Int?
  pesoSugerido         Float?
  zonaIntensidad       ZonaIntensidad?
  cadencia             String?
  duracionSerie        String?
  notasTecnicas        String?
  orden                Int
  esTesteo             Boolean           @default(false)
  modalidadTesteo      ModalidadTesteo?
  grupoId              String?
  nombreGrupo          String?
  diaSesion            DiaSesion         @relation(fields: [diaId], references: [id])
  ejercicio            Ejercicio?        @relation(fields: [ejercicioId], references: [id])
  seriesRegistradas    SerieRegistrada[]
}

model SesionRegistrada {
  id              String            @id @default(uuid())
  clienteId       String
  diaId           String
  fecha           DateTime          @default(now())
  completada      Boolean           @default(false)
  duracionMinutos Int?
  metricas        MetricasSesion?
  series          SerieRegistrada[]
  cliente         Cliente           @relation(fields: [clienteId], references: [id])
  diaSesion       DiaSesion         @relation(fields: [diaId], references: [id])
}

model SerieRegistrada {
  id                     String               @id @default(uuid())
  sesionId               String
  ejercicioPlanificadoId String
  pesoKg                 Float?
  repsReales             Int?
  velocidadPercibida     VelocidadPercibida?
  completada             Boolean              @default(false)
  notas                  String?
  ejercicioPlanificado   EjercicioPlanificado @relation(fields: [ejercicioPlanificadoId], references: [id])
  sesionRegistrada       SesionRegistrada     @relation(fields: [sesionId], references: [id])
}

model MetricasSesion {
  id                    String           @id @default(uuid())
  sesionId              String           @unique
  duracion              Int?
  DOMS                  String?
  grupoMuscularFatigado String?
  pesajeDia             Float?
  esfuerzoGral          Int?
  sesionRegistrada      SesionRegistrada @relation(fields: [sesionId], references: [id])
}

model PerfilRespuesta {
  id              String          @id @default(uuid())
  clienteId       String          @unique
  nivelRespuesta  NivelRespuesta?
  fechaEvaluacion DateTime?
  notas           String?
  cliente         Cliente         @relation(fields: [clienteId], references: [id])
}

model AlertaEstancamiento {
  id               String    @id @default(uuid())
  clienteId        String
  ejercicioId      String
  semanasEstancado Int
  revisada         Boolean   @default(false)
  creadaEn         DateTime  @default(now())
  cliente          Cliente   @relation(fields: [clienteId], references: [id])
  ejercicio        Ejercicio @relation(fields: [ejercicioId], references: [id])
}

model RegistroAdherencia {
  id                   String  @id @default(uuid())
  clienteId            String
  semanaId             String
  sesionesPlanificadas Int
  sesionesCompletadas  Int
  porcentaje           Float
  cliente              Cliente @relation(fields: [clienteId], references: [id])
}

model Checkin {
  id               String   @id @default(uuid())
  clienteId        String
  fecha            DateTime @default(now())
  fotosUrls        String[]
  pesoKg           Float?
  nota             String?
  energia          Int?
  sueno            Int?
  adherencia       Int?
  faseCiclo        String?
  ajustesEsperados String?
  alturaCm         Float?
  fuerzaRelativa   String?
  videoUrl         String?
  visto            Boolean  @default(false)
  cliente          Cliente  @relation(fields: [clienteId], references: [id])
}

model Cobro {
  id             String        @id @default(uuid())
  clienteId      String
  fecha          DateTime      @default(now())
  montoArs       Float
  metodo         String
  periodoDesde   DateTime
  periodoHasta   DateTime
  notas          String?
  planAsignadoId String?
  comprobanteUrl String?
  cliente        Cliente       @relation(fields: [clienteId], references: [id])
  planAsignado   PlanAsignado? @relation(fields: [planAsignadoId], references: [id])
}

model Mensaje {
  id        String   @id @default(uuid())
  clienteId String
  emisor    String
  contenido String
  tipo      String
  creadoEn  DateTime @default(now())
  leido     Boolean  @default(false)
  mediaUrl  String?
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
}

model ResultadoTesteo {
  id             String          @id @default(uuid())
  clienteId      String
  ejercicioId    String
  modalidad      ModalidadTesteo
  pesoUtilizado  Float
  repsRealizadas Int
  unRMCalculado  Float
  fuerzaRelativa Float
  mesocicloId    String?
  fecha          DateTime        @default(now())
  notas          String?
  cliente        Cliente         @relation(fields: [clienteId], references: [id])
  ejercicio      Ejercicio       @relation(fields: [ejercicioId], references: [id])
}

model ConfigTesteoEjercicio {
  id                    String          @id @default(uuid())
  semanaId              String
  ejercicioId           String
  modalidad             ModalidadTesteo
  repsObjetivoIndirecto Int?
  orden                 Int
  ejercicio             Ejercicio       @relation(fields: [ejercicioId], references: [id])
  semana                Semana          @relation(fields: [semanaId], references: [id])
}

model PorcentajesCliente {
  id              String          @id @default(uuid())
  clienteId       String
  ejercicioId     String
  unRM            Float
  modalidadTesteo ModalidadTesteo
  fechaTesteo     DateTime
  p100            Float
  p94_3           Float
  p90_6           Float
  p88_1           Float
  p85_6           Float
  p83_1           Float
  p80_7           Float
  p78_6           Float
  p76_5           Float
  p74_4           Float
  p72_3           Float
  p70_3           Float
  p68_8           Float
  p67_5           Float
  p66_2           Float
  p65_0           Float
  p63_8           Float
  p62_7           Float
  actualizadoEn   DateTime        @updatedAt
  cliente         Cliente         @relation(fields: [clienteId], references: [id])
  ejercicio       Ejercicio       @relation(fields: [ejercicioId], references: [id])

  @@unique([clienteId, ejercicioId])
}

model Notificacion {
  id           String           @id @default(uuid())
  entrenadorId String
  tipo         TipoNotificacion
  gravedad     GravedadNotificacion @default(INFO)
  titulo       String
  cuerpo       String
  leida        Boolean              @default(false)
  purgada      Boolean          @default(false)
  creadaEn     DateTime         @default(now())
  entrenador   Entrenador       @relation(fields: [entrenadorId], references: [id])
}

model NotaEntrenador {
  id            String     @id @default(uuid())
  entrenadorId  String
  contenido     String
  orden         Int
  creadaEn      DateTime   @default(now())
  actualizadaEn DateTime   @updatedAt
  entrenador    Entrenador @relation(fields: [entrenadorId], references: [id])
}

model RutinaPlantilla {
  id            String            @id @default(uuid())
  entrenadorId  String
  nombre        String
  descripcion   String?
  categoria     String?
  creadaEn      DateTime          @default(now())
  actualizadaEn DateTime          @updatedAt
  ejercicios    EjercicioRutina[]
  entrenador    Entrenador        @relation(fields: [entrenadorId], references: [id])
}

model EjercicioRutina {
  id            String          @id @default(uuid())
  rutinaId      String
  ejercicioId   String?
  nombreLibre   String?
  series        Int
  repsMin       Int
  repsMax       Int
  descansoSeg   Int
  tempo         String?
  metodo        String?
  notasTecnicas String?
  orden         Int
  ejercicio     Ejercicio?      @relation(fields: [ejercicioId], references: [id])
  rutina        RutinaPlantilla @relation(fields: [rutinaId], references: [id], onDelete: Cascade)
}

model ConfigLanding {
  id                String     @id @default(uuid())
  entrenadorId      String     @unique
  heroTitulo        String?
  heroSubtitulo     String?
  heroImagenUrl     String?
  bioTexto          String?
  bioImagenUrl      String?
  testimonios       Json?
  faqs              Json?
  footerTexto       String?
  modoMantenimiento Boolean    @default(false)
  creadaEn          DateTime   @default(now())
  actualizadaEn     DateTime   @updatedAt
  entrenador        Entrenador @relation(fields: [entrenadorId], references: [id])
}

enum GrupoMuscular {
  CUADRICEPS
  ISQUIOTIBIALES
  GLUTEO
  PECHO
  ESPALDA
  HOMBROS
  BICEPS
  TRICEPS
  CORE
  GEMELOS
  ADUCTORES
  ABDOMINALES
  LUMBARES
  TRAPECIO
  ANTEBRAZOS
}

enum TipoArticulacion {
  MONOARTICULAR
  BIARTICULAR
  MULTIARTICULAR
}

enum PatronMovimiento {
  EMPUJE_HORIZONTAL
  EMPUJE_VERTICAL
  TRACCION_HORIZONTAL
  TRACCION_VERTICAL
  BISAGRA
  SENTADILLA
  AISLAMIENTO
  ISOMETRICO
  CARGADA_OLIMPICA
  CAMINATA_TRANSPORTE
}

enum TipoEquipamiento {
  MAQUINA
  BARRA
  MANCUERNA
  POLEA
  BANDA_ELASTICA
  PESO_CORPORAL
  TRX
  KETTLEBELL
  MULTIPOWER
  BANCO
  DISCO
  CABLE
}

enum Lateralidad {
  BILATERAL
  UNILATERAL
}

enum PosicionCarga {
  LONGITUD_LARGA
  LONGITUD_CORTA
  NEUTRA
}

enum NivelTecnico {
  BASICO
  INTERMEDIO
  AVANZADO
}

enum OrigenEjercicio {
  BIBLIOTECA_IL
  PERSONALIZADO
}

enum TipoCarga {
  INTRODUCTORIA
  BASE
  CHOQUE
  DESCARGA_TEST
}

enum ModeloPeriodizacion {
  LINEAL
  ONDULANTE
  CONJUGADA
  PERSONALIZADO
}

enum VelocidadPercibida {
  NORMAL
  LENTA
  MUY_LENTA
}

enum NivelRespuesta {
  ALTA
  NORMAL
  BAJA
}

enum ZonaIntensidad {
  NEURAL
  NEURO_ENDOCRINA
  HIPERTROFIA
  RESISTENCIA
}

enum ModalidadTesteo {
  DIRECTO
  INDIRECTO
}

enum TipoNotificacion {
  MENSAJE_DIRECTO
  FINANZA
  VENCIMIENTO_MEMBRESIA
  NUEVO_FORMULARIO
  CHECKIN
}

enum GravedadNotificacion {
  INFO
  ALERTA
  CRITICO
}

model RegistroAutenticacion {
  id            String    @id @default(uuid())
  ip            String    @unique
  intentos      Int       @default(1)
  bloqueadoHasta DateTime?
  ultimoIntento DateTime  @default(now())
}

model GamificacionCliente {
  id              String   @id @default(uuid())
  clienteId       String   @unique
  nivel           Int      @default(1)
  experiencia     Int      @default(0)
  rachaDias       Int      @default(0)
  ultimoCheckin   DateTime?
  logrosGenerales String[] // Array de keys de logros
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

