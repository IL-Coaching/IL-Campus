# Variables de Entorno de IL-Campus (Template)
# Copiá este archivo a .env y configurá los valores reales.

# ==========================================
# BASE DE DATOS (Supabase / Prisma)
# ==========================================
# URL de conexión directa a PostgreSQL
DATABASE_URL="postgresql://user:password@host:port/database?pgbouncer=true"

# URL adicional para conexiones Edge / Pooled
DIRECT_URL="postgresql://user:password@host:port/database"

# ==========================================
# AUTENTICACIÓN (Supabase)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ==========================================
# EMAIL (Resend)
# ==========================================
RESEND_API_KEY="re_your_api_key"
EMAIL_REMITENTE="IL-Coaching <contacto@tu-dominio.com>"

# ==========================================
# CONFIGURACIÓN DEL SITIO
# ==========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMERO="5491112345678"

# Secreto para JWT (generar uno fuerte de 32+ caracteres)
JWT_SECRET="generate-a-strong-secret-here"
